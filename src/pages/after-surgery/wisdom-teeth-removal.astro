  <script type="application/ld+json" slot="head">{JSON.stringify({ "@context": "https://schema.org", "@graph": [
    { "@type": "MedicalWebPage", "name": "After Wisdom Tooth Removal", "url": "https://www.greatlakessurgerycentre.com/after-surgery/wisdom-teeth-removal", "description": "Post-operative care instructions after wisdom tooth removal including irrigation syringe guidance for the weeks following surgery.", "specialty": "Oral and Maxillofacial Surgery" },
    { "@type": "FAQPage", "mainEntity": [
      { "@type": "Question", "name": "What should I do immediately after wisdom tooth removal?", "acceptedAnswer": { "@type": "Answer", "text": "Keep the gauze pad in place for 20 minutes, then discard it. Avoid vigorous rinsing, spitting, or touching the wound as this can dislodge the blood clot and cause bleeding. Take prescribed pain medications before discomfort begins. Restrict activities on the day of surgery." } },
      { "@type": "Question", "name": "How do I manage bleeding after wisdom tooth removal?", "acceptedAnswer": { "@type": "Answer", "text": "Slight bleeding or redness in saliva is normal for 48 hours. Control excessive bleeding by wiping old clots from your mouth, then biting firmly on a gauze pad for 30 minutes. If bleeding continues, bite on a moistened tea bag for 30 minutes — the tannic acid helps form a blood clot. Sit upright and avoid exertion." } },
      { "@type": "Question", "name": "How long does swelling last after wisdom tooth removal?", "acceptedAnswer": { "@type": "Answer", "text": "Swelling around the mouth, cheeks, eyes, and face is common. It may not appear until the day after surgery and reaches its maximum at 2-3 days. Apply ice packs intermittently for 20-30 minute intervals for the first 48 hours. Sleep with your head elevated at least 45 degrees for the first 4 days." } },
      { "@type": "Question", "name": "What can I eat after wisdom tooth removal?", "acceptedAnswer": { "@type": "Answer", "text": "Begin with liquids after IV anesthesia. Do not use straws as the sucking motion can dislodge the blood clot. Eat soft foods by chewing away from the surgical sites. High calorie, high protein intake is important. Stay hydrated." } },
      { "@type": "Question", "name": "How do I use the irrigation syringe after wisdom tooth removal?", "acceptedAnswer": { "@type": "Answer", "text": "Starting one week after surgery, stop using Peridex and begin using the irrigation syringe. Fill it with diluted mouthwash, warm salt water, or plain warm water. Pull your cheek out to open the wisdom tooth socket, gently place the tip 1mm inside the hole, and flush. Irrigate after every meal or at least morning and evening for 3-4 weeks until the socket is completely closed. Flush only the lower jaw sockets as gravity collects food there." } },
      { "@type": "Question", "name": "How long does pain last after wisdom tooth removal?", "acceptedAnswer": { "@type": "Answer", "text": "Pain may last 5-7 days. Take pain medications as directed. Call the office if medication is not working. If antibiotics are prescribed, complete the full course. The prescription pain medication may make you drowsy — do not drive or operate machinery." } }
    ]},
    { "@type": "HowTo", "name": "How to Irrigate Your Wisdom Tooth Socket", "description": "Starting one week after wisdom tooth removal, use the irrigation syringe daily to flush food debris from the lower wisdom tooth sockets to prevent infection and promote healing.", "totalTime": "PT5M", "tool": [{ "@type": "HowToTool", "name": "Irrigation syringe (provided at your post-op appointment)" }, { "@type": "HowToTool", "name": "Warm salt water, diluted mouthwash, or plain warm water" }], "step": [{ "@type": "HowToStep", "position": 1, "name": "Fill the syringe", "text": "Fill the irrigation syringe with diluted mouthwash, warm salt water (a teaspoon of salt in a cup of warm water), or plain warm water." }, { "@type": "HowToStep", "position": 2, "name": "Open the socket", "text": "Stand in front of a mirror. Pull your cheek out using your finger or toothbrush to open the wisdom tooth socket so you can see clearly and position the syringe properly." }, { "@type": "HowToStep", "position": 3, "name": "Flush the socket", "text": "Gently place the tip of the syringe 1mm inside the hole and flush with the warm water. You may see food debris, dried blood, or a stitch come out — this is normal." }, { "@type": "HowToStep", "position": 4, "name": "Repeat until clear", "text": "If debris comes out, repeat irrigation until none remains. Irrigate after every meal, or at least once in the morning and once in the evening. Continue for 3-4 weeks or until the lower socket is completely closed and you cannot insert the syringe tip." }] },
    { "@type": "VideoObject", "name": "How to Irrigate Your Wisdom Tooth Socket — Great Lakes Oral Surgery", "description": "A step-by-step video demonstration of how to use the irrigation syringe to flush wisdom tooth sockets after surgery, provided by Great Lakes Oral & Maxillofacial Surgery Centre.", "thumbnailUrl": "https://img.youtube.com/vi/KkFmJsH2x-I/maxresdefault.jpg", "uploadDate": "2020-01-01", "embedUrl": "https://www.youtube.com/embed/KkFmJsH2x-I", "contentUrl": "https://www.youtube.com/watch?v=KkFmJsH2x-I", "publisher": { "@type": "Organization", "name": "Great Lakes Oral & Maxillofacial Surgery Centre", "url": "https://www.greatlakessurgerycentre.com" } }
