---
import Layout from '../../layouts/Layout.astro';
import SidebarLayout from '../../components/shared/SidebarLayout.astro';
import Accordion from '../../components/shared/Accordion.astro';

import { afterSurgeryNavItems as navItems } from '../../data/surgeryNavItems';
---

<Layout description="Discharge instructions for facial trauma including nasal fractures, jaw fractures, and lacerations. Great Lakes Oral Surgery, Windsor."
  title="After Facial Trauma - Great Lakes Oral & Maxillofacial Surgery Centre">
  <script type="application/ld+json" slot="head">{JSON.stringify({ "@context": "https://schema.org", "@graph": [
    { "@type": "MedicalWebPage", "name": "After Facial Trauma — Discharge Instructions", "url": "https://www.greatlakessurgerycentre.com/after-surgery/facial-trauma", "description": "Discharge instructions for facial trauma including nasal fractures, jaw fractures, and lacerations. Great Lakes Oral Surgery, Windsor.", "specialty": "Oral and Maxillofacial Surgery" },
    { "@type": "FAQPage", "mainEntity": [
      { "@type": "Question", "name": "What should I do after a nasal bone fracture?", "acceptedAnswer": { "@type": "Answer", "text": "Keep ice to the top of the nose for the first day if the nose is not splinted. If splinted and packed, maintain the splint and packing until seen in the office. Do not blow your nose. Avoid heavy lifting or strenuous exercise. Sleep with head elevated with pillows for the first 3-4 days. Call the office if bleeding continues." } },
      { "@type": "Question", "name": "What should I do after a jaw fracture?", "acceptedAnswer": { "@type": "Answer", "text": "Keep ice to the area for the first 2 days. Sleep with head elevated for 3-4 days. Eat only soft foods and liquids — no chewing. Keep the mouth clean by rinsing and brushing teeth. If elastics or wires fall off, wait until your next office visit. Although you may be able to open and close your jaw, it is still considered broken for 4-6 weeks after injury. Plates and screws placed will remain unless otherwise indicated." } },
      { "@type": "Question", "name": "What should I do after a cheekbone or orbital bone fracture?", "acceptedAnswer": { "@type": "Answer", "text": "Keep ice to the face in the fracture area for the first 1-2 days. Sleep with head elevated for 3-4 days. Do not sleep on the affected side. Do not blow your nose. Numbness to the fracture side of the face is normal and may or may not resolve. If you experience pain or loss of vision in the eye, call the office or go to the Emergency Room immediately." } },
      { "@type": "Question", "name": "How should I care for facial lacerations after surgery?", "acceptedAnswer": { "@type": "Answer", "text": "Keep wounds clean and clear of scabs. Apply antibiotic ointment to wounds twice daily after cleaning. Maintain any dressing placed in the office. Avoid sun exposure for 6 months to a year by applying complete block sunscreen to wounds once healed, to prevent scarring." } }
    ]}
  ]})}</script>
  <SidebarLayout title="After a Procedure" navItems={navItems} currentPath={Astro.url.pathname}>
    <Fragment slot="card-header">
      <h2>After Facial Trauma</h2>
      <p class="text-sm leading-relaxed" style="color: #515151;">Discharge Instructions for Facial Trauma.</p>
    </Fragment>

    <Accordion title="Fractured Nasal Bone (Nose)">
      <ul class="list-disc pl-5 space-y-1">
          <li>Keep ice to top of nose for first day if nose is not splinted</li>
          <li>
            If nose is splinted and packed, maintain splint and packing until
            seen in office
          </li>
          <li>No nose blowing</li>
          <li>No heavy lifting or strenuous exercise</li>
          <li>Sleep with head elevated with pillows for first 3 to 4 days</li>
          <li>If nose continues to bleed, call the office</li>
        </ul>
    </Accordion>

    <Accordion title="Maxillary Mandible Fractures (Upper and Lower Jaws)">
      <ul class="list-disc pl-5 space-y-1">
          <li>Keep ice to area of broken bone for first 2 days</li>
          <li>Sleep with head elevated for first 3 to 4 days</li>
          <li>Keep mouth clean by rinsing and brushing teeth</li>
          <li>Diet - soft foods & liquids only. NO CHEWING!</li>
          <li>
            If elastics or wired shut and 1 or 2 fall off, no need to worry
            until next office visit
          </li>
          <li>No heavy lifting or strenuous exercise</li>
          <li>
            If jaws wired shut, may use straw for delivery of soft foods and
            liquids
          </li>
          <li>
            If sutures have been placed and profuse bleeding from incision site,
            call the office
          </li>
          <li>
            If sutures have been placed and a couple dislodge, no need to worry
          </li>
          <li>
            If swelling increases after the 3rd or 4th day, call the office
          </li>
          <li>
            Although you may be able to open and close your lower jaw, you must
            remember it is considered still broken 4-6 weeks after the injury
          </li>
          <li>
            Plates and screws that have been placed will be maintained unless
            otherwise indicated for removal
          </li>
          <li>
            Remember a numb feeling to the lower lip, chin, or tongue area may
            be normal with the particular fracture. This may or may not resolve
            in time.
          </li>
          <li>
            If fractured jaw not repaired as of yet & sent home, still follow
            above applicable instructions
          </li>
          <li>Clean bars & wires on teeth as well as brushing teeth</li>
        </ul>
    </Accordion>

    <Accordion title="Zygomatico-Orbital Fractures (Cheek Bone/Orbital Bone Fractures)">
      <ul class="list-disc pl-5 space-y-1">
          <li>
            Keep ice to face in area of fracture for first 1-2 days after
            fracture/surgery
          </li>
          <li>
            Sleep with head elevated with pillows for the first 3 to 4 days
          </li>
          <li>
            Remember that numbness to the fracture side of the face is normal
            for this particular fracture and may or may not resolve with time
          </li>
          <li>Do not sleep on affected side of face</li>
          <li>
            If pain or loss of vision in eye, call the office or go to the
            Emergency Room immediately
          </li>
          <li>
            Double vision may be normal for this type of fracture & may resolve
            with surgery or time
          </li>
          <li>No nose blowing</li>
          <li>No heavy lifting or strenuous exercise</li>
          <li>Apply antibiotic ointment to surgical incision 2 times a day</li>
        </ul>
    </Accordion>

    <Accordion title="Dento-Alveolar Fracture (Tooth & Gum Injuries)">
      <ul class="list-disc pl-5 space-y-1">
          <li>Soft foods and liquid for diet</li>
          <li>Expect that hot and cold temperatures may cause sensitivity</li>
          <li>
            Expect that root canal treatment may be necessary in the near future
          </li>
          <li>Brush teeth and keep wires clean</li>
          <li>
            If increase in swelling, pain and/or associated bad taste in mouth
            please call the office and make an appointment
          </li>
        </ul>
    </Accordion>

    <Accordion title="Lacerations">
      <ul class="list-disc pl-5 space-y-1">
          <li>Keep wounds clean and clear of scabs</li>
          <li>
            Apply antibiotic ointment to wounds after cleaning 2 times a day
          </li>
          <li>
            If dressing is placed over wounds, maintain dressing seen in the
            office
          </li>
          <li>
            Avoid sun exposure for first 6 months to a year by applying complete
            block sunscreen to wounds once healed
          </li>
        </ul>
    </Accordion>
    <p class="mt-6 pt-6 border-t border-gray-100 text-sm text-center leading-relaxed" style="color: #515151;">
      If you have any questions or concerns don't hesitate to call the office to speak with a nurse. <a href="tel:519-979-7227" style="color:#3A959B;font-weight:bold;text-decoration:none">(519)-979-7227</a>
    </p>
  </SidebarLayout>
</Layout>
