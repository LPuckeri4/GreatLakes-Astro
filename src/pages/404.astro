---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found - Great Lakes Oral & Maxillofacial Surgery Centre"
  description="The page you are looking for could not be found."
>
  <div class="min-h-screen flex flex-col items-center justify-center text-center px-5" style="background:#f5f5f5">
    <h1 class="text-7xl font-bold mb-4" style="color:#3A959B">404</h1>
    <h2 class="text-2xl mb-6">Page Not Found</h2>
    <p class="mb-8 max-w-[40ch]" style="color:#515151">
      The page you are looking for doesn't exist or has been moved.
    </p>
    <a href="/" class="btn-teal">Return Home</a>
  </div>
</Layout>
