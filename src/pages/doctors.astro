---
import Layout from '../layouts/Layout.astro';
import { Picture } from 'astro:assets';
import shuren1Src from '../assets/images/shuren1.png';
import stapleford1Src from '../assets/images/stapleford1.png';
---

<Layout
  title="Doctors - Great Lakes Oral & Maxillofacial Surgery Centre"
  description="Dr. Mark Shuren and Dr. Richard Stapleford are board-certified oral and maxillofacial surgeons serving Windsor and Essex County, Ontario at Great Lakes Oral Surgery."
>
  <script type="application/ld+json" slot="head">
  [
    {
      "@context": "https://schema.org",
      "@type": "Physician",
      "name": "Dr. Mark Shuren",
      "givenName": "Mark",
      "familyName": "Shuren",
      "honorificPrefix": "Dr.",
      "honorificSuffix": "HONS.B.SC., DDS, FRCD(C), Dip. ABOMS",
      "jobTitle": "Oral and Maxillofacial Surgeon",
      "medicalSpecialty": "Oral and Maxillofacial Surgery",
      "description": "Dr. Mark Shuren is a board-certified oral and maxillofacial surgeon who has practiced in Windsor and Essex County since 1996. He is a Diplomate of the American Board of Oral and Maxillofacial Surgery, a Fellow of the Royal College of Dentists of Canada, and an Adjunct Clinical Professor at Western University Schulich School of Medicine and Dentistry. He is the first director and instructor of Advanced Cardiac Life Support (ACLS) in Essex County.",
      "worksFor": {
        "@type": "MedicalClinic",
        "name": "Great Lakes Oral & Maxillofacial Surgery Centre",
        "url": "https://www.greatlakessurgerycentre.com",
        "telephone": "+1-519-979-7227",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "1825 Manning Road, Studio 700",
          "addressLocality": "Tecumseh",
          "addressRegion": "ON",
          "postalCode": "N9K 0A9",
          "addressCountry": "CA"
        }
      },
      "alumniOf": [
        { "@type": "CollegeOrUniversity", "name": "University of Western Ontario", "description": "Bachelor of Science" },
        { "@type": "CollegeOrUniversity", "name": "University of Windsor", "description": "Honours Degree" },
        { "@type": "CollegeOrUniversity", "name": "McGill University", "description": "Doctor of Dental Surgery (DDS), 1991" },
        { "@type": "CollegeOrUniversity", "name": "Medical Center of Delaware", "description": "Oral and Maxillofacial Surgery Residency, completed 1996" }
      ],
      "hasCredential": [
        { "@type": "EducationalOccupationalCredential", "name": "Fellow, Royal College of Dentists of Canada (FRCD(C))", "credentialCategory": "Professional Fellowship" },
        { "@type": "EducationalOccupationalCredential", "name": "Diplomate, American Board of Oral and Maxillofacial Surgery (ABOMS)", "credentialCategory": "Board Certification" },
        { "@type": "EducationalOccupationalCredential", "name": "Adjunct Clinical Professor, Western University Schulich School of Medicine and Dentistry", "credentialCategory": "Academic Appointment" },
        { "@type": "EducationalOccupationalCredential", "name": "National Board Examiner, Oral and Maxillofacial Surgery", "credentialCategory": "Professional Appointment" }
      ],
      "knowsAbout": [
        "Dental Implants", "Wisdom Teeth Removal", "Bone Grafting", "Facial Trauma", "Orthognathic Surgery",
        "Oral Pathology", "TMJ Disorders", "Tooth Extraction", "CBCT Imaging", "Piezoelectric Surgery"
      ],
      "areaServed": ["Windsor, Ontario", "Tecumseh, Ontario", "Essex County, Ontario"]
    },
    {
      "@context": "https://schema.org",
      "@type": "Physician",
      "name": "Dr. Richard Stapleford",
      "givenName": "Richard",
      "familyName": "Stapleford",
      "honorificPrefix": "Dr.",
      "honorificSuffix": "DDS, FRCD(C), Dip. ABOMS",
      "jobTitle": "Chief of Oral and Maxillofacial Surgery",
      "medicalSpecialty": "Oral and Maxillofacial Surgery",
      "description": "Dr. Richard Stapleford is a board-certified oral and maxillofacial surgeon with over 30 years of specialty practice in Windsor and Essex County. He serves as Chief of Oral and Maxillofacial Surgery and Dentistry at Windsor Regional Hospitals, is an Adjunct Clinical Professor at UWO Schulich School of Medicine and Dentistry, and is a consultant at the Windsor Regional Cancer Treatment Centre and the John McGivney Children's Centre Maxillofacial Cleft Palate Clinic.",
      "worksFor": {
        "@type": "MedicalClinic",
        "name": "Great Lakes Oral & Maxillofacial Surgery Centre",
        "url": "https://www.greatlakessurgerycentre.com",
        "telephone": "+1-519-979-7227",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "1825 Manning Road, Studio 700",
          "addressLocality": "Tecumseh",
          "addressRegion": "ON",
          "postalCode": "N9K 0A9",
          "addressCountry": "CA"
        }
      },
      "alumniOf": [
        { "@type": "CollegeOrUniversity", "name": "University of Western Ontario", "description": "Undergraduate and Doctoral Education" },
        { "@type": "CollegeOrUniversity", "name": "University of Toronto", "description": "Postgraduate Training" },
        { "@type": "CollegeOrUniversity", "name": "Henry Ford Hospital, Detroit", "description": "Oral and Maxillofacial Surgery Training and Practice" }
      ],
      "hasCredential": [
        { "@type": "EducationalOccupationalCredential", "name": "Fellow, Royal College of Dentists of Canada (FRCD(C))", "credentialCategory": "Professional Fellowship" },
        { "@type": "EducationalOccupationalCredential", "name": "Diplomate, American Board of Oral and Maxillofacial Surgery (ABOMS)", "credentialCategory": "Board Certification" },
        { "@type": "EducationalOccupationalCredential", "name": "Chief of Oral and Maxillofacial Surgery, Windsor Regional Hospitals", "credentialCategory": "Hospital Appointment" },
        { "@type": "EducationalOccupationalCredential", "name": "Adjunct Clinical Professor, Western University Schulich School of Medicine and Dentistry", "credentialCategory": "Academic Appointment" },
        { "@type": "EducationalOccupationalCredential", "name": "Diplomate, National Dental Board of Anesthesiology (USA)", "credentialCategory": "Board Certification" },
        { "@type": "EducationalOccupationalCredential", "name": "Thesis Examiner, School of Graduate Studies, Western University", "credentialCategory": "Academic Appointment" }
      ],
      "award": [
        "Ontario Society of Oral and Maxillofacial Surgeons Award of Merit",
        "University of Detroit Award for Excellence in Teaching and Patient Care",
        "Schulich School of Medicine and Dentistry Teaching Recognition Award",
        "American Board of Oral and Maxillofacial Surgery Examination Committee Award"
      ],
      "knowsAbout": [
        "Maxillofacial Injuries and Fractures", "Reconstructive and Jaw Surgery", "Temporomandibular Joint Surgery",
        "Oral Pathology", "Dental Implants", "Bone Grafting", "Wisdom Teeth Removal", "Cleft Palate", "Oral Cancer"
      ],
      "areaServed": ["Windsor, Ontario", "Tecumseh, Ontario", "Essex County, Ontario"]
    }
  ]
  </script>
  <!-- Hero -->
  <div style="background-image:url('/references/herobg-1.jpg');background-size:cover;background-position:center;border-bottom:1px solid rgba(58,149,155,0.15);">
    <div style="max-width:80rem;margin:0 auto;padding:72px 4rem 68px;text-align:center;">
      <span style="display:inline-block;font-size:0.7rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#3A959B;margin-bottom:14px;">Our Surgical Team</span>
      <h1 style="font-family:'Playfair Display',serif;font-size:3rem;font-weight:400;color:#1a2e35;margin:0 0 16px;line-height:1.15;">Meet Our Doctors</h1>
      <p style="font-size:1rem;color:#5a6b72;margin:0 auto;line-height:1.6;max-width:520px;">Our experienced oral and maxillofacial surgeons provide specialized care with compassion, skill, and advanced training.</p>
    </div>
  </div>

  <div style="background:#f6f6f6;" class="min-h-screen pt-12 pb-16 px-5">

    <!-- Dr. Shuren -->
    <div class="max-w-[1100px] mx-auto mb-8">
      <div class="doctor-card">
      <div class="flex flex-wrap items-start gap-6">
        <!-- Photo -->
        <div class="flex justify-center w-full sm:w-auto sm:flex-shrink-0">
          <Picture src={shuren1Src} formats={["avif", "webp"]} alt="Dr. Mark Shuren" class="w-[200px] sm:w-[240px] h-auto rounded-xl" />
        </div>
        <!-- Bio + Table -->
        <div class="flex-1 flex flex-wrap gap-6 min-w-0">
          <div class="flex-1 min-w-[240px]">
            <h2 class="text-2xl mb-1">Dr. Mark Shuren</h2>
            <p class="text-sm text-gray-500 mb-5">HONS.B.SC., DDS, FRCD(C), Dip. ABOMS</p>
            <p class="leading-relaxed mb-4" style="color:#515151">
              Dr. Shuren grew up in Windsor, Ontario. He graduated from the University of Western Ontario in 1986 with a Bachelors of Science Degree. He completed an Honours Degree at the University of Windsor in 1987. Dr. Shuren attended McGill University School of Dentistry and graduated in 1991.
            </p>
            <div id="bio-shuren" class="bio-extra" style="color:#515151">
              <p>
                In 1992, he served in a General Practice Residency internship at The Medical Center of Delaware in Delaware, USA. Dr. Shuren completed a four year Oral and Maxillofacial Surgery residency at the Medical Center of Delaware in 1996. He completed his Fellowship in Oral and Maxillofacial Surgery from the Royal College of Dentists of Canada (FRCD) this same year.
              </p>
              <br />
              <p>
                In 1996, Dr. Shuren, his wife Pam, and their three children returned to Canada to practice in his hometown. Dr. Shuren has been in private practice in Windsor since 1996. He has initiated Advanced Cardio Life Support courses in Essex County and became the first director and instructor of ACLS in the community.
              </p>
              <br />
              <p>
                In 1999, Dr. Shuren passed his American Boards in the United States and was awarded Diplomat status by the American Board of Oral and Maxillofacial Surgery (Board Certified). He was re-certified again in 2010.
              </p>
              <br />
              <p>
                In September of 2009, Dr. Shuren built a new practice located at 1825 Manning Road in Tecumseh, Ontario to better serve his patients' needs from a comfort and technologically advanced approach. Dr. Shuren is a National Board Examiner in the speciality of Oral and Maxillofacial Surgery to certify new professionals in the field.
              </p>
              <br />
              <p>
                Dr. Shuren has had extensive training in all areas of oral and maxillofacial surgery. He operates at his office and at both local hospitals – Windsor Regional Hospital Ouellete &amp; Metropolitan Campus. Dr. Shuren has been appointed as an Adjunct Clinical Professor and Preceptor to Western University Schulich School of Medicine &amp; Dentistry, London and Windsor campus, in the training program for dual degree (M.D. and D.D.S.) Oral and Maxillofacial Surgery.
              </p>
            </div>
            <button class="btn-teal mt-4" data-bio="bio-shuren">Read More</button>
          </div>
          <!-- Quick Facts -->
          <div class="w-full sm:w-[240px] flex-shrink-0">
            <div class="qf-card">
              <div class="qf-header">Quick Facts</div>
              <div class="qf-body">
                <p class="qf-label">Specialty</p>
                <p class="qf-value">Oral and Maxillofacial Surgery</p>
                <p class="qf-label mt-4">Education & Training</p>
                <ul class="qf-list">
                  <li>BSc - University of Western Ontario</li>
                  <li>Honours Degree - University of Windsor</li>
                  <li>D.D.S. - McGill University</li>
                  <li>Residency/Training - Medical Center of Delaware</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
      </div>
    </div>

    <!-- Dr. Stapleford -->
    <div class="max-w-[1100px] mx-auto mb-8">
      <div class="doctor-card">
      <div class="flex flex-wrap items-start gap-6">
        <!-- Photo -->
        <div class="flex justify-center w-full sm:w-auto sm:flex-shrink-0">
          <Picture src={stapleford1Src} formats={["avif", "webp"]} alt="Dr. Richard Stapleford" class="w-[200px] sm:w-[240px] h-auto rounded-xl" />
        </div>
        <!-- Bio + Table -->
        <div class="flex-1 flex flex-wrap gap-6 min-w-0">
          <div class="flex-1 min-w-[240px]">
            <h2 class="text-2xl mb-1">Dr. Richard Stapleford</h2>
            <p class="text-sm text-gray-500 mb-5">DDS, FRCD(C), Dip. ABOMS</p>
            <p class="leading-relaxed mb-4" style="color:#515151">
              Dr. Stapleford joined the Great Lakes Oral and Maxillofacial Surgery Centre in January 2011 after thirty years of specialty practice in Windsor and Essex County. He currently serves as Chief of Oral and Maxillofacial Surgery and Dentistry at Windsor Regional Hospitals. Dr. Stapleford is an Adjunct Clinical Professor in the Department of Surgery at the UWO Schulich School of Medicine and Dentistry as well as a consultant at both The Windsor Regional Cancer Treatment Centre and The John McGivney Children's Centre Maxillofacial Cleft Palate Clinic.
            </p>
            <div id="bio-stapleford" class="bio-extra" style="color:#515151">
              <p>
                Dr. Stapleford received his undergraduate and doctoral education at the University of Western Ontario followed by postgraduate training at the University of Toronto and University of Western Ontario. He trained in oral and maxillofacial surgery in the Department of Surgery at the Henry Ford Hospital, Detroit Michigan and practiced and taught at that institution until 1981 when he returned to Windsor while continuing to teach at the University of Detroit Mercy.
              </p>
              <br />
              <p>
                Dr. Stapleford has successfully completed the specialty examinations of both the American Board of Oral and Maxillofacial Surgery and the Royal College of Dental Surgeons of Canada and has served as an advisor and examiner for both specialty organizations. Dr. Stapleford has been appointed as an Adjunct Clinical Professor and Preceptor to Western University Schulich School of Medicine &amp; Dentistry, London and Windsor campus, in the training program for dual degree (M.D. and D.D.S.) Oral and Maxillofacial Surgery. Further, Dr. Stapleford is a Preceptor and Lecturer in the Department of Surgery of Schulich, Windsor, in Facial Trauma and applied Surgical Anatomy. In addition, he has completed the examination for diplomate status with the National Dental Board of Anesthesiology (U.S.A.).
              </p>
              <br />
              <p>
                His teaching awards include the Ontario Society of Oral and Maxillofacial Surgeons Award of Merit, the University of Detroit Award for Excellence in Teaching and Patient Care, The Schulich School of Medicine and Dentistry Teaching Recognition Award and the American Board of Oral and Maxillofacial Surgery Examination Committee Award.
              </p>
              <br />
              <p>
                Most recently, Dr. Stapleford has been appointed to the school of Graduate studies of Western University as a Thesis Examiner.
              </p>
              <br />
              <p>
                Consistent with the scope of practice offered at Great Lakes Oral and Maxillofacial Surgery Centre, Dr. Stapleford maintains strong interest in the treatment of maxillofacial injuries and fractures, reconstructive and jaw surgery; including the temporomandibular joint, benign and malignant oral pathology, dental implants and bone grafting as well as wisdom teeth and dental extractions using local and general anesthesia.
              </p>
              <br />
              <p>
                Outside of his professional activity Dr. Stapleford devotes his time to his wife, Diana and their five children and six grandchildren.
              </p>
            </div>
            <button class="btn-teal mt-4" data-bio="bio-stapleford">Read More</button>
          </div>
          <!-- Quick Facts -->
          <div class="w-full sm:w-[240px] flex-shrink-0">
            <div class="qf-card">
              <div class="qf-header">Quick Facts</div>
              <div class="qf-body">
                <p class="qf-label">Specialty</p>
                <p class="qf-value">Oral and Maxillofacial Surgery</p>
                <p class="qf-label mt-4">Education & Training</p>
                <ul class="qf-list">
                  <li>BSc - University of Western Ontario</li>
                  <li>D.D.S. - University of Western Ontario</li>
                  <li>Residency/Training - UofT, Henry Ford Hospital</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  document.querySelectorAll('button[data-bio]').forEach(btn => {
    const bio = document.getElementById(btn.getAttribute('data-bio')!);
    btn.addEventListener('click', () => {
      const open = bio!.classList.toggle('open');
      btn.textContent = open ? 'Read Less' : 'Read More';
    });
  });
</script>

<style>
  .bio-extra {
    display: none;
    margin-top: 16px;
    line-height: 1.75;
  }
  .bio-extra.open {
    display: block;
  }

  .doctor-card {
    background: white;
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    padding: 28px;
  }

  .qf-card {
    background: white;
    border-radius: 12px;
    border: 1px solid #e5e7eb;
    overflow: hidden;
  }
  .qf-header {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #3A959B;
    padding: 12px 16px 10px;
    border-bottom: 1px solid #e5e7eb;
    margin: 0;
  }
  .qf-body {
    padding: 0;
  }
  .qf-section {
    padding: 12px 16px;
    border-bottom: 1px solid #f3f4f6;
  }
  .qf-section:last-child {
    border-bottom: none;
  }
  .qf-label {
    font-size: 0.65rem;
    font-weight: 600;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 4px;
  }
  .qf-value {
    font-size: 0.85rem;
    font-weight: 500;
    color: #1f2937;
    margin: 0;
  }
  .qf-list {
    list-style: disc;
    padding-left: 14px;
    margin: 0;
  }
  .qf-list li {
    font-size: 0.8rem;
    color: #374151;
    margin-bottom: 2px;
    line-height: 1.5;
  }
</style>
