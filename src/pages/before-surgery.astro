---
import Layout from '../layouts/Layout.astro';
import { getImage } from 'astro:assets';
import herobgSrc from '../assets/images/herobg-1.jpg';
const heroBg = await getImage({ src: herobgSrc, format: 'webp' });
---

<Layout
  title="Before Surgery Instructions | Great Lakes Oral Surgery"
  description="Pre-operative instructions for oral surgery patients in Windsor and Essex County. What to wear, eat, and prepare before your appointment at Great Lakes Oral Surgery."
>
  <script type="application/ld+json" slot="head">{JSON.stringify({ "@context": "https://schema.org", "@graph": [
    { "@type": "MedicalWebPage", "name": "Instructions Before Surgery", "url": "https://www.greatlakessurgerycentre.com/before-surgery", "description": "Pre-operative instructions for patients at Great Lakes Oral & Maxillofacial Surgery Centre.", "specialty": "Oral and Maxillofacial Surgery" },
    { "@type": "FAQPage", "mainEntity": [
      { "@type": "Question", "name": "What should I wear to oral surgery?", "acceptedAnswer": { "@type": "Answer", "text": "Please wear loose fitting clothing with short sleeves and low-heeled, secure fitting shoes. No flip flops. Remove contact lenses, jewelry, and dentures at the time of surgery. Tongue and lip piercings must be removed prior to surgery. Do not wear lipstick, excessive make-up, or nail polish on the day of surgery." } },
      { "@type": "Question", "name": "What should I do if I am sick before my surgery?", "acceptedAnswer": { "@type": "Answer", "text": "If you have an illness such as a cold, sore throat, sinus infection, or stomach or bowel upset, please notify the office as soon as possible before your scheduled surgery." } },
      { "@type": "Question", "name": "Can I eat or drink before oral surgery with IV sedation?", "acceptedAnswer": { "@type": "Answer", "text": "You may not have anything to eat or drink (including water) for eight (8) hours prior to surgery. If you eat or drink before a planned IV anesthetic, your case will need to be rescheduled or cancelled. To proceed would put you at increased risk for otherwise avoidable complications." } },
      { "@type": "Question", "name": "Do I need someone to drive me home after oral surgery?", "acceptedAnswer": { "@type": "Answer", "text": "A responsible adult must accompany the patient to the office, remain during the procedure, drive the patient home, and spend a minimum of 18 hours with them — or longer if drowsiness or dizziness persists. No exceptions. The patient should not drive a vehicle, operate machinery, make important financial decisions, or drink alcohol for 24 hours following anesthesia." } },
      { "@type": "Question", "name": "Can I smoke before oral surgery?", "acceptedAnswer": { "@type": "Answer", "text": "No smoking for at least 12 hours before surgery. Ideally, cut down or stop smoking as soon as possible prior to the day of surgery." } }
    ]}
  ]})}</script>

  <!-- Hero -->
  <div style={`background-image:url('${heroBg.src}');`} class="bg-cover bg-center border-b border-[rgba(58,149,155,0.15)]">
    <div class="max-w-7xl mx-auto px-6 md:px-16 pt-12 md:pt-[72px] pb-10 md:pb-[68px] text-center">
      <span class="inline-block text-[0.7rem] font-bold tracking-[0.14em] uppercase text-[#3A959B] mb-[14px]">Patient Resources</span>
      <h1 class="text-3xl md:text-5xl font-normal text-[#1a2e35] mt-0 mb-4 leading-[1.15]">Before Surgery</h1>
      <p class="text-base text-[#5a6b72] mx-auto leading-relaxed max-w-[520px] m-0">Please read these instructions carefully before your scheduled surgery appointment.</p>
    </div>
  </div>

  <div class="bg-[#f6f6f6] min-h-screen pt-10 pb-20 px-5">
    <div class="max-w-[860px] mx-auto space-y-6">

      <!-- General Instructions -->
      <div class="bg-white rounded-2xl shadow-[0_4px_24px_rgba(0,0,0,0.08)] overflow-hidden">
        <div class="bg-[rgba(58,149,155,0.1)] border-b border-[rgba(58,149,155,0.2)] px-9 py-6">
          <h2 class="text-2xl font-normal text-[#222222] m-0">Instructions Before Surgery</h2>
        </div>
        <ul class="list-disc pt-7 pb-7 pr-9 pl-14 space-y-3 m-0">
          <li class="text-[#515151] text-[0.9375rem] leading-7">Please wear loose fitting clothing with short sleeves and low-heeled, secure fitting shoes. <strong>(NO FLIP FLOPS!!)</strong></li>
          <li class="text-[#515151] text-[0.9375rem] leading-7">Contact lenses, jewelry, and dentures must be removed at the time of surgery.</li>
          <li class="text-[#515151] text-[0.9375rem] leading-7">Tongue/lip piercings must be removed prior to surgery.</li>
          <li class="text-[#515151] text-[0.9375rem] leading-7">Do not wear lipstick, excessive make-up, or nail polish on the day of surgery.</li>
          <li class="text-[#515151] text-[0.9375rem] leading-7">If you have an illness such as a cold, sore throat, sinus infection, stomach or bowel upset, please notify the office as soon as possible before your scheduled surgery.</li>
          <li class="text-[#515151] text-[0.9375rem] leading-7">Please make prior arrangements before surgery to have someone available to check on you throughout the day, after surgery, or to provide assistance at night if needed.</li>
          <li class="text-[#515151] text-[0.9375rem] leading-7">Please take medications as directed by the Doctor before your scheduled surgery.</li>
          <li class="text-[#515151] text-[0.9375rem] leading-7">Patients under the age of 18 <em>MUST</em> be accompanied by a parent or legal guardian at the time of their surgery.</li>
        </ul>
      </div>

      <!-- IV Sedation Instructions -->
      <div class="bg-white rounded-2xl shadow-[0_4px_24px_rgba(0,0,0,0.08)] overflow-hidden">
        <div class="bg-[rgba(58,149,155,0.1)] border-b border-[rgba(58,149,155,0.2)] px-9 py-6">
          <h2 class="text-2xl font-normal text-[#222222] m-0">Before IV Deep or Conscious Sedation</h2>
        </div>
        <ul class="list-disc pt-7 pb-7 pr-9 pl-14 space-y-3 m-0">
          <li class="text-[#515151] text-[0.9375rem] leading-7">
            You may not have anything to eat or drink <strong>(including water)</strong> for eight (8) hours prior to surgery. If you have anything to eat or drink before a planned IV anesthetic, it is important that you inform the Doctor upon your arrival. Eating or drinking prior to a planned IV anesthetic will necessitate your case be rescheduled or cancelled. To proceed would put the patient in increased risk for otherwise avoidable complications.
          </li>
          <li class="text-[#515151] text-[0.9375rem] leading-7">No smoking at least 12 hours before surgery. Ideally, cut down or stop smoking as soon as possible prior to the day of surgery.</li>
          <li class="text-[#515151] text-[0.9375rem] leading-7">
            <span class="underline">A responsible adult must accompany the patient to the office, remain in the office during the procedure, drive the patient home and spend a minimum of 18 hours or longer if drowsiness or dizziness persists. NO exceptions!!</span>
          </li>
          <li class="text-[#515151] text-[0.9375rem] leading-7">Patients who normally take prescription medication should do so with the smallest sip of water necessary, as directed by the Doctor before a scheduled IV anesthetic.</li>
          <li class="text-[#515151] text-[0.9375rem] leading-7">We recommend purchasing ice packs prior to your surgery as they will be used post operatively.</li>
          <li class="text-[#515151] text-[0.9375rem] leading-7">Please remember to use the restroom immediately before your appointment time.</li>
          <li class="text-[#515151] text-[0.9375rem] leading-7">
            <span class="underline">The patient should not drive a vehicle, operate machinery, make important financial decisions or drink alcohol for 24 hours following the anesthesia experience.</span>
          </li>
        </ul>
      </div>

      <!-- Call CTA -->
      <div class="rounded-xl border-l-4 border-[#3A959B] bg-gradient-to-r from-[rgba(58,149,155,0.1)] to-[rgba(58,149,155,0.04)] shadow-sm flex items-start gap-[18px] p-5">
        <div class="w-[46px] h-[46px] rounded-full bg-[#3A959B] flex items-center justify-center shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" width="22" height="22">
            <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 011 1V20a1 1 0 01-1 1C10.61 21 3 13.39 3 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.58a1 1 0 01-.25 1.01l-2.2 2.2z"/>
          </svg>
        </div>
        <div>
          <p class="font-semibold text-[#222222] text-[0.95rem] mb-1">Have Questions or Concerns?</p>
          <p class="text-sm text-[#555] leading-relaxed mb-1.5">Don't hesitate to call the office to speak with a nurse.</p>
          <a href="tel:5199797227" class="text-[0.95rem] font-semibold text-[#3A959B] no-underline hover:underline">519-979-7227</a>
        </div>
      </div>

    </div>
  </div>
</Layout>
