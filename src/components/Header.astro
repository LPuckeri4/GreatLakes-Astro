---
const navLinks = [
  { label: 'Home', href: '/', activePrefix: '/' },
  { label: 'Surgery', href: '/surgery/dental-implants', activePrefix: '/surgery' },
  { label: 'Doctors', href: '/doctors', activePrefix: '/doctors' },
  { label: 'After Surgery', href: '/after-surgery/general-instructions', activePrefix: '/after-surgery' },
  { label: 'About', href: '/about', activePrefix: '/about' },
];

const resourceLinks = [
  { label: 'Download Forms', href: '/downloads' },
  { label: 'Online Payment', href: '/payment' },
  { label: 'Patient Referral', href: 'https://v3.expressregistration.ca/prod/view.php?id=52423' },
];

const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  class="fixed top-0 w-full z-50 transition-all duration-500 min-h-[100px] flex items-center"
>
  <!-- Desktop nav -->
  <nav class="hidden md:flex items-center justify-around w-full px-5 lg:px-8">
    <a href="/">
      <img
        src="/img/GreatLakesLogo.png"
        alt="Great Lakes Oral & Maxillofacial Surgery"
        class="w-[250px] lg:w-[350px]"
      />
    </a>

    <div class="flex items-center">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'relative mx-4 lg:mx-6 text-sm lg:text-base text-[#222222] no-underline nav-link',
            (link.activePrefix === '/' ? currentPath === '/' : currentPath.startsWith(link.activePrefix)) && 'active-link',
          ]}
        >
          {link.label}
        </a>
      ))}

      <!-- Resources dropdown -->
      <div class="dropdown dropdown-hover relative mx-4 lg:mx-6">
        <div tabindex="0" role="button" class="flex items-center gap-1 text-sm lg:text-base text-[#222222] cursor-pointer nav-link">
          Resources
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </div>
        <ul tabindex="0" class="dropdown-content menu bg-white shadow-lg rounded-none p-0 w-48 z-50 border-t-2 border-[#3A959B]">
          {resourceLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="text-[#222222] hover:bg-[#deeded] hover:text-[#222222] rounded-none text-sm px-4 py-3"
                {...link.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <a
        href="/#contact"
        class="ml-8 lg:ml-12 border border-[#222222] text-[#222222] px-6 py-2 text-sm lg:text-base contact-btn"
      >
        Contact
      </a>
    </div>
  </nav>

  <!-- Mobile nav -->
  <div class="md:hidden flex items-center w-full px-4">
    <button id="mobile-menu-btn" aria-label="Open menu" class="text-[#222222] mr-4">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
    <a href="/" class="flex-1 flex justify-center">
      <img src="/img/GreatLakesLogo.png" alt="Great Lakes" class="w-[75%] max-w-[350px]" />
    </a>
  </div>
</header>

<!-- Mobile drawer overlay -->
<div id="drawer-overlay" class="fixed inset-0 bg-black/40 z-40 hidden md:hidden"></div>

<!-- Mobile drawer -->
<div
  id="mobile-drawer"
  class="fixed top-0 left-0 h-full w-60 bg-white z-50 transform -translate-x-full transition-transform duration-300 md:hidden flex flex-col"
>
  <div class="flex flex-col items-center pt-6 pb-4 border-b border-gray-200">
    <a href="/" id="drawer-logo-link">
      <img src="/img/GreatLakesLogo.png" alt="Great Lakes" class="w-[180px]" />
    </a>
  </div>
  <nav class="flex flex-col text-center">
    {[...navLinks.map(l => ({ label: l.label, href: l.href })), ...resourceLinks].map(link => (
      <a
        href={link.href}
        class="py-3 px-4 text-[#222222] border-b border-gray-100 hover:bg-[#deeded] text-sm"
        {...link.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
      >
        {link.label}
      </a>
    ))}
    <a href="/#contact" class="py-3 px-4 text-[#222222] border-b border-gray-100 hover:bg-[#deeded] text-sm">
      Contact
    </a>
  </nav>
</div>

<style>
  .nav-link {
    position: relative;
  }
  .nav-link::before {
    content: '';
    position: absolute;
    width: 0;
    height: 2px;
    bottom: -2px;
    left: 0;
    background-color: #222222;
    visibility: hidden;
    transition: all 0.2s ease-in-out;
  }
  .nav-link:hover::before {
    visibility: visible;
    width: 100%;
  }
  .active-link::before {
    visibility: visible;
    width: 100%;
  }
  .contact-btn {
    background-image: linear-gradient(#222222, #222222);
    background-position: 50% 50%;
    background-repeat: no-repeat;
    background-size: 0% 100%;
    transition: background-size 0.5s, color 0.5s;
  }
  .contact-btn:hover {
    color: white;
    background-size: 100% 100%;
  }
</style>

<script>
  const header = document.getElementById('site-header')!;
  const menuBtn = document.getElementById('mobile-menu-btn')!;
  const drawer = document.getElementById('mobile-drawer')!;
  const overlay = document.getElementById('drawer-overlay')!;

  function openDrawer() {
    drawer.classList.remove('-translate-x-full');
    overlay.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    drawer.classList.add('-translate-x-full');
    overlay.classList.add('hidden');
    document.body.style.overflow = '';
  }

  menuBtn.addEventListener('click', openDrawer);
  overlay.addEventListener('click', closeDrawer);
  drawer.querySelectorAll('a').forEach(a => a.addEventListener('click', closeDrawer));

  function updateHeader() {
    if (window.scrollY > 0) {
      header.classList.add('bg-white/70', 'backdrop-blur-md', 'shadow-md');
    } else {
      header.classList.remove('bg-white/70', 'backdrop-blur-md', 'shadow-md');
    }
  }

  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();
</script>
