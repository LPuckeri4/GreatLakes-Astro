---
import { Image } from 'astro:assets';
import callIcon from '../../assets/images/call.png';
import locationIcon from '../../assets/images/location.png';
import calendarIcon from '../../assets/images/calendar.png';
---

<div class="contact-cards w-full relative z-10">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

      <!-- Contact Us -->
      <a href="tel:519-734-4235" class="card block bg-white rounded-lg p-5 no-underline text-inherit">
        <div class="flex items-start gap-4">
          <div class="card-icon w-12 h-12 rounded-full bg-[#3A959B] flex items-center justify-center flex-shrink-0">
            <Image src={callIcon} alt="call" width={22} class="invert" />
          </div>
          <div>
            <p class="sans-heading font-bold text-[#3A959B] text-base mb-1">Contact Us</p>
            <div class="w-8 h-0.5 bg-[#3A959B] mb-2"></div>
            <p class="text-sm text-gray-500 mb-2">Call us by phone during our regular business hours.</p>
            <p class="text-[#3A959B] text-xl font-bold">(519) 734-4235</p>
          </div>
        </div>
      </a>

      <!-- Our Location -->
      <a
        href="https://maps.app.goo.gl/RR1CFZ7nuH5dH26KA"
        target="_blank"
        rel="noopener noreferrer"
        class="card block bg-white rounded-lg p-5 no-underline text-inherit"
      >
        <div class="flex items-start gap-4">
          <div class="card-icon w-12 h-12 rounded-full bg-[#3A959B] flex items-center justify-center flex-shrink-0">
            <Image src={locationIcon} alt="location" width={22} class="invert" />
          </div>
          <div>
            <p class="sans-heading font-bold text-[#3A959B] text-base mb-1">Our Location</p>
            <div class="w-8 h-0.5 bg-[#3A959B] mb-2"></div>
            <p class="text-sm text-gray-500">1825 Manning Rd | Studio 700 Tecumseh | ON | N9K 0A9</p>
          </div>
        </div>
      </a>

      <!-- Hours of Operation -->
      <a href="#contact" class="card block bg-white rounded-lg p-5 no-underline text-inherit">
        <div class="flex items-start gap-4">
          <div class="card-icon w-12 h-12 rounded-full bg-[#3A959B] flex items-center justify-center flex-shrink-0">
            <Image src={calendarIcon} alt="hours" width={22} class="invert" />
          </div>
          <div>
            <p class="sans-heading font-bold text-[#3A959B] text-base mb-1">Hours of Operation</p>
            <div class="w-8 h-0.5 bg-[#3A959B] mb-2"></div>
            <p class="text-sm text-gray-500">
              Mon to Thurs: 8:00 AM – 5:00 PM<br />
              Friday: 8:00 AM – 3:00 PM
            </p>
          </div>
        </div>
      </a>

    </div>
  </div>
</div>

<style>
  .card {
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.13);
    border: 1px solid #f3f4f6;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }
  .card:hover {
    transform: translateY(-5px);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.22);
    border-color: #3A959B;
  }
  .card-icon {
    transition: transform 0.25s ease;
  }
  .card:hover .card-icon {
    transform: scale(1.1);
  }
  .contact-cards {
    animation: slideUp 1s ease-out 0.7s both;
  }
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(60px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
