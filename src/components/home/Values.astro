<div class="max-w-7xl mx-auto px-6 lg:px-8 py-12">
  <!-- Our Values + Quality + Health -->
  <div class="flex flex-wrap">
    <div class="w-full sm:w-1/3 flex flex-col items-center sm:items-start mb-8">
      <div class="w-[90%] border-t border-gray-400 mb-8"></div>
      <h2 class="text-3xl mb-1">Our Values</h2>
      <div class="underline-blue mb-8" data-animate-underline-b></div>
    </div>
    <div class="w-full sm:w-1/3 flex flex-col mb-8">
      <div class="w-[90%] border-t border-gray-400 mb-8 hidden sm:block"></div>
      <h3 class="text-2xl mb-4">Quality</h3>
      <p class="pr-[5%]" style="color: #515151">
        Great Lakes Oral & Maxillofacial Surgery Centre takes great pride in bringing their patients
        the latest in technologically advanced, comfort oriented oral and maxillofacial surgical care.
      </p>
    </div>
    <div class="w-full sm:w-1/3 flex flex-col mb-8">
      <div class="w-[90%] border-t border-gray-400 mb-8 hidden sm:block"></div>
      <h3 class="text-2xl mb-4">Health</h3>
      <p class="pr-[5%]" style="color: #515151">
        Our office is independently inspected outpatient surgical facilities, and are equipped with
        modern specialized equipment. They are staffed with a highly trained, experienced and
        compassionate team of caring professionals.
      </p>
    </div>
  </div>

  <!-- About Us -->
  <div class="flex flex-wrap items-start">
    <div class="w-full sm:w-1/3 flex flex-col items-center sm:items-start mb-8">
      <h2 class="text-3xl mt-8 mb-1">About us</h2>
      <div class="underline-blue mb-8" data-animate-underline-b></div>
    </div>
    <div class="w-full sm:w-2/3 mb-8">
      <p class="mt-8" style="color: #515151">
        Great Lakes Oral & Maxillofacial Surgery Centre is a team of highly trained and experienced
        professionals committed to providing the highest quality of care to their patients. Their
        expertise includes the diagnosis and treatment of oral and maxillofacial problems, ranging
        from simple to complex procedures. They offer advanced technologically equipped outpatient
        surgical facilities with certified medical specialists in anesthesia, ensuring optimal care
        and safety. The team takes great pride in providing their patients with a comfortable and
        pleasant experience while using the latest technology in oral and maxillofacial surgical care.
      </p>
    </div>
  </div>

  <a href="/about" class="btn-teal w-[240px]" aria-label="Learn more about our practice and values">Learn More</a>
</div>

<style>
  .underline-blue {
    height: 3px;
    width: 0;
    background-image: linear-gradient(to left, rgba(255,0,0,0), #114c74 50%);
    background-repeat: no-repeat;
    transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .underline-blue.visible { width: 70%; }
</style>

<script>
  document.querySelectorAll('[data-animate-underline-b]').forEach(el => {
    const obs = new IntersectionObserver(entries => {
      if (entries[0].isIntersecting) { el.classList.add('visible'); obs.disconnect(); }
    }, { rootMargin: '-20% 0px' });
    obs.observe(el);
  });
</script>
