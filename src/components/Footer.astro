---
import { Image } from 'astro:assets';
import logoSrc from '../assets/images/GreatLakesLogo.png';

const year = new Date().getFullYear();

const quickLinks = [
  { label: 'Home', href: '/' },
  { label: 'Surgery', href: '/surgery/dental-implants' },
  { label: 'After Surgery', href: '/after-surgery/general-instructions' },
  { label: 'Doctors', href: '/doctors' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/#contact' },
];

const resourceLinks = [
  { label: 'Download Forms', href: '/downloads' },
  { label: 'Before Surgery', href: '/before-surgery' },
  { label: 'Online Payment', href: '/payment' },
  { label: 'Patient Referral', href: 'https://v3.expressregistration.ca/prod/view.php?id=52423', external: true },
];
---

<footer class="site-footer">

  <!-- Multi-peak wave SVG -->
  <div class="footer-wave" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 90" preserveAspectRatio="none">
      <path fill="white" d="M0,60 C240,10 480,85 720,48 C960,10 1200,85 1440,60 L1440,0 L0,0 Z"/>
    </svg>
  </div>

  <div class="footer-inner">
    <div class="footer-grid">

      <!-- Brand -->
      <section class="footer-brand">
        <a class="footer-logo" href="/" aria-label="Great Lakes Oral & Maxillofacial Surgery Centre home">
          <Image src={logoSrc} alt="Great Lakes Oral & Maxillofacial Surgery Centre" width={280} densities={[1, 2]} />
        </a>
        <p>
          Providing compassionate, expert care in oral and maxillofacial surgery
          with advanced technology and a patient-first approach.
        </p>
        <div class="footer-socials" aria-label="Social links">
          <a href="https://share.google/ATJPzOMAqXTT2hnGk" target="_blank" rel="noopener noreferrer" aria-label="Review us on Google">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
          </a>
        </div>
      </section>

      <!-- Quick Links + Resources -->
      <nav class="footer-column" aria-label="Footer navigation">
        <h3>Quick Links</h3>
        <ul>
          {quickLinks.map(link => (
            <li>
              <a href={link.href}>
                <span class="chevron">›</span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        <h3 class="subheading">Resources</h3>
        <ul>
          {resourceLinks.map(link => (
            <li>
              <a href={link.href} {...link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}>
                <span class="chevron">›</span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Contact -->
      <section class="footer-column footer-contact">
        <h3>Contact Information</h3>
        <ul>
          <li>
            <span class="footer-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2A19.8 19.8 0 0 1 3.08 5.18 2 2 0 0 1 5.06 3h3a2 2 0 0 1 2 1.72c.13.96.35 1.9.66 2.8a2 2 0 0 1-.45 2.11L9 10.91a16 16 0 0 0 4.09 4.09l1.28-1.28a2 2 0 0 1 2.11-.45c.9.31 1.84.53 2.8.66A2 2 0 0 1 22 16.92Z" />
              </svg>
            </span>
            <a href="tel:5199797227">519-979-7227</a>
          </li>
          <li>
            <span class="footer-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M21 10c0 7-9 12-9 12S3 17 3 10a9 9 0 1 1 18 0Z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
            </span>
            <a href="https://maps.app.goo.gl/RR1CFZ7nuH5dH26KA" target="_blank" rel="noopener noreferrer">
              1825 Manning Rd<br />Studio 700 Tecumseh | ON | N9K 0A9
            </a>
          </li>
          <li>
            <span class="footer-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m22 6-10 7L2 6" />
              </svg>
            </span>
            <a href="mailto:info@greatlakesomsc.com">info@greatlakesomsc.com</a>
          </li>
        </ul>
      </section>

      <!-- Hours -->
      <section class="footer-column footer-hours">
        <h3>Office Hours</h3>
        <div class="hours-block">
          <span class="footer-icon large" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="9" />
              <path d="M12 7v5l3 2" />
            </svg>
          </span>
          <div>
            <p>Mon to Thurs: 8:00 AM – 5:00 PM</p>
            <p>Friday: 8:00 AM – 3:00 PM</p>
          </div>
        </div>
        <div class="hours-note">
          We are closed on weekends<br />and statutory holidays.
        </div>
      </section>

    </div>

    <div class="footer-bottom">
      <p>© {year} Great Lakes Oral &amp; Maxillofacial Surgery Centre. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at 12% 20%, rgba(54, 150, 155, 0.1), transparent 32%),
      linear-gradient(180deg, #f1f8f9 0%, #e2f2f3 100%);
    color: #31343a;
  }

  /* ── Wave ── */
  .footer-wave {
    position: absolute;
    inset: 0 0 auto 0;
    line-height: 0;
    pointer-events: none;
  }
  .footer-wave svg {
    display: block;
    width: 100%;
    height: 90px;
  }

  /* ── Inner ── */
  .footer-inner {
    position: relative;
    max-width: 1240px;
    margin: 0 auto;
    padding: 110px 32px 34px;
  }

  /* ── Grid ── */
  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 0.85fr 1.2fr 1fr;
    gap: 46px;
    align-items: start;
  }
  .footer-brand, .footer-column { min-width: 0; }
  .footer-grid > * + * {
    border-left: 1px solid rgba(34, 124, 132, 0.18);
    padding-left: 46px;
  }

  /* ── Brand ── */
  .footer-logo { display: inline-block; margin-bottom: 24px; }
  .footer-logo img { display: block; width: min(280px, 100%); height: auto; }
  .footer-brand p {
    max-width: 300px;
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.8;
    color: #5d646b;
  }

  /* ── Socials ── */
  .footer-socials { display: flex; gap: 12px; margin-top: 26px; }
  .footer-socials a {
    display: inline-grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 999px;
    background: #258c91;
    color: #fff;
    text-decoration: none;
    box-shadow: 0 6px 16px rgba(37, 140, 145, 0.2);
    transition: transform 180ms ease, background 180ms ease;
  }
  .footer-socials a:hover { transform: translateY(-2px); background: #146f76; }

  /* ── Column headings ── */
  .footer-column h3 {
    margin: 0 0 20px;
    color: #187e85;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.25rem;
    font-weight: 400;
    letter-spacing: 0.035em;
  }
  .footer-column h3::after {
    content: "";
    display: block;
    width: 38px;
    height: 2px;
    margin-top: 11px;
    background: #258c91;
  }
  /* Sub-heading for Resources inside Quick Links column */
  .footer-column h3.subheading {
    margin-top: 16px;
  }

  /* ── Links ── */
  .footer-column ul { list-style: none; padding: 0; margin: 0; }
  .footer-column li + li { margin-top: 6px; }
  .footer-column a { color: #4f565e; text-decoration: none; transition: color 160ms ease; font-size: 0.93rem; }
  .footer-column a:hover { color: #187e85; }
  .chevron { display: inline-block; margin-right: 10px; color: #187e85; font-size: 1.2em; line-height: 1; }

  /* ── Contact grid ── */
  .footer-contact li {
    display: grid;
    grid-template-columns: 26px 1fr;
    gap: 14px;
    align-items: start;
    color: #4f565e;
    line-height: 1.55;
    font-size: 0.93rem;
  }

  /* ── Icons ── */
  .footer-icon { display: inline-flex; align-items: center; justify-content: center; color: #258c91; }
  .footer-icon svg { width: 20px; height: 20px; stroke: currentColor; fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
  .footer-icon.large svg { width: 26px; height: 26px; }

  /* ── Hours ── */
  .hours-block { display: grid; grid-template-columns: 32px 1fr; gap: 16px; align-items: start; color: #4f565e; }
  .hours-block p { margin: 0; line-height: 1.65; font-size: 0.93rem; }

  .hours-note {
    position: relative;
    margin-top: 28px;
    padding-top: 22px;
    color: #5d646b;
    font-style: italic;
    line-height: 1.8;
    font-size: 0.88rem;
  }
  .hours-note::before {
    content: "";
    position: absolute;
    left: 0; top: 0;
    width: 48px; height: 1px;
    background: #258c91;
  }

  /* ── Bottom bar ── */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    align-items: center;
    margin-top: 52px;
    padding-top: 24px;
    border-top: 1px solid rgba(34, 124, 132, 0.18);
    color: #687078;
    font-size: 0.88rem;
  }
  .footer-bottom p { margin: 0; }
  .footer-legal { display: flex; align-items: center; gap: 20px; }
  .footer-legal a { color: #187e85; text-decoration: none; }
  .footer-legal a:hover { text-decoration: underline; }

  /* ── Responsive ── */
  @media (max-width: 1050px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
    .footer-grid > * { border-left: 0 !important; padding-left: 0 !important; }
    .footer-grid > *:nth-child(even) {
      border-left: 1px solid rgba(34, 124, 132, 0.18) !important;
      padding-left: 32px !important;
    }
  }

  @media (max-width: 640px) {
    .footer-inner { padding: 100px 20px 24px; }
    .footer-grid { grid-template-columns: 1fr; gap: 32px; }
    .footer-grid > * { border-left: 0 !important; padding-left: 0 !important; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
    .footer-legal { gap: 12px; flex-wrap: wrap; }
  }
</style>
