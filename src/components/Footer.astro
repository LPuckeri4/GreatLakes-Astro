---
import { Image } from 'astro:assets';
import logowhited from '../assets/images/logowhited.png';
---

<footer class="bg-[#292D2D] w-full py-5">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
  <!-- Desktop -->
  <div class="hidden sm:flex items-center w-full min-h-[100px]">
    <div class="flex flex-col w-1/3 gap-1">
      <a href="/" class="text-white no-underline hover:opacity-80 text-sm">Home</a>
      <a href="/downloads" class="text-white no-underline hover:opacity-80 text-sm">Download forms</a>
      <a href="/#contact" class="text-white no-underline hover:opacity-80 text-sm">Contact</a>
    </div>
    <div class="flex justify-center w-1/3">
      <a href="/">
        <Image src={logowhited} alt="Great Lakes" class="w-full max-w-[350px]" />
      </a>
    </div>
    <div class="flex justify-center w-1/3">
      <p class="text-white text-xs text-center">Site By: Lukas Puckerin Web Development</p>
    </div>
  </div>

  <!-- Mobile -->
  <div class="flex flex-col items-center w-full gap-4 sm:hidden min-h-[100px] justify-center">
    <a href="/">
      <Image src={logowhited} alt="Great Lakes" class="w-[70%] max-w-[300px]" />
    </a>
    <div class="flex flex-row justify-around w-full">
      <a href="/" class="text-white no-underline hover:opacity-80 text-sm">Home</a>
      <a href="/downloads" class="text-white no-underline hover:opacity-80 text-sm">Download forms</a>
      <a href="/#contact" class="text-white no-underline hover:opacity-80 text-sm">Contact</a>
    </div>
    <p class="text-white text-xs text-center">Site By: Lukas Puckerin Web Development</p>
  </div>
  </div>
</footer>
