---
import { Image } from "astro:assets";
import logoSrc from "../assets/images/GreatLakesLogo.png";

const year = new Date().getFullYear();

const quickLinks = [
  { label: "Home", href: "/" },
  { label: "Surgery", href: "/surgery/dental-implants" },
  { label: "After Surgery", href: "/after-surgery/general-instructions" },
  { label: "Doctors", href: "/doctors" },
  { label: "About", href: "/about" },
  { label: "Contact", href: "/#contact" },
];

const resourceLinks = [
  { label: "Download Forms", href: "/downloads" },
  { label: "Before Surgery", href: "/before-surgery" },
  { label: "Online Payment", href: "/payment" },
  {
    label: "Patient Referral",
    href: "https://v3.expressregistration.ca/prod/view.php?id=52423",
    external: true,
  },
];
---

<footer class="site-footer">
  <div class="footer-wave" aria-hidden="true">
    <svg viewBox="0 0 1600 160" preserveAspectRatio="none">
      <path
        d="M0 54C160 22 315 36 500 42C710 48 845 10 1035 20C1238 31 1408 62 1600 36V160H0V54Z"
        fill="currentColor"></path>
    </svg>
  </div>

  <div class="footer-surface">
    <div class="footer-inner">
      <!-- Brand -->
      <section class="footer-brand">
        <a
          class="footer-logo"
          href="/"
          aria-label="Great Lakes Oral & Maxillofacial Surgery Centre home"
        >
          <Image
            src={logoSrc}
            alt="Great Lakes Oral & Maxillofacial Surgery Centre"
            width={310}
            densities={[1, 2]}
          />
        </a>
        <p>
          Providing compassionate, expert care in oral and maxillofacial surgery
          with advanced technology and a patient-first approach.
        </p>
        <a
          class="google-link"
          href="https://share.google/ATJPzOMAqXTT2hnGk"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Review us on Google"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            width="16"
            height="16"
          >
            <path
              d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
            ></path>
            <path
              d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
            ></path>
            <path
              d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
            ></path>
            <path
              d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
            ></path>
          </svg>
        </a>
      </section>

      <!-- Quick Links + Resources -->
      <nav class="footer-col footer-links" aria-label="Footer navigation">
        <h3>Quick Links</h3>
        <ul>
          {
            quickLinks.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))
          }
        </ul>
        <h3 class="resources-title">Resources</h3>
        <ul>
          {
            resourceLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  {...(link.external
                    ? { target: "_blank", rel: "noopener noreferrer" }
                    : {})}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- Contact -->
      <section class="footer-col">
        <h3>Contact Information</h3>
        <ul class="footer-contact">
          <li>
            <span class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"
                ><path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2A19.8 19.8 0 0 1 3.08 5.18 2 2 0 0 1 5.06 3h3a2 2 0 0 1 2 1.72c.13.96.35 1.9.66 2.8a2 2 0 0 1-.45 2.11L9 10.91a16 16 0 0 0 4.09 4.09l1.28-1.28a2 2 0 0 1 2.11-.45c.9.31 1.84.53 2.8.66A2 2 0 0 1 22 16.92Z"
                ></path></svg
              >
            </span>
            <a href="tel:5199797227">519-979-7227</a>
          </li>
          <li>
            <span class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"
                ><path d="M21 10c0 7-9 12-9 12S3 17 3 10a9 9 0 1 1 18 0Z"
                ></path><circle cx="12" cy="10" r="3"></circle></svg
              >
            </span>
            <a
              href="https://maps.app.goo.gl/RR1CFZ7nuH5dH26KA"
              target="_blank"
              rel="noopener noreferrer"
            >
              1825 Manning Rd<br />Studio 700 Tecumseh | ON | N9K 0A9
            </a>
          </li>
          <li>
            <span class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"
                ><rect x="2" y="4" width="20" height="16" rx="2"></rect><path
                  d="m22 6-10 7L2 6"></path></svg
              >
            </span>
            <a href="mailto:info@greatlakesomsc.com">info@greatlakesomsc.com</a>
          </li>
        </ul>
      </section>

      <!-- Hours -->
      <section class="footer-col">
        <h3>Office Hours</h3>
        <div class="hours-row">
          <span class="icon" aria-hidden="true">
            <svg viewBox="0 0 24 24"
              ><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"
              ></path></svg
            >
          </span>
          <div>
            <p>Mon to Thurs: 8:00 AM – 5:00 PM</p>
            <p>Friday: 8:00 AM – 3:00 PM</p>
          </div>
        </div>
        <div class="closed-note">
          We are closed on weekends<br />and statutory holidays.
        </div>
      </section>
    </div>

    <div class="footer-bottom">
      <p>
        © {year} Great Lakes Oral &amp; Maxillofacial Surgery Centre. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    --footer-bg: #e6f1f2;
    --footer-text: #414950;
    --footer-muted: #576168;
    --footer-teal: #0f7d84;
    --footer-line: rgba(15, 125, 132, 0.16);

    position: relative;
    color: var(--footer-text);
  }

  /* transparent behind the wave */
  .footer-wave {
    position: absolute;
    z-index: 1;
    left: 0;
    right: 0;
    top: -78px;
    height: 160px;
    color: var(--footer-bg);
    pointer-events: none;
  }

  .footer-wave svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* actual footer fill starts under the wave */
  .footer-surface {
    position: relative;
    z-index: 2;
    background: var(--footer-bg);
    padding: clamp(2.5rem, 4vw, 3.5rem) 1.5rem 2rem;
  }

  .footer-inner {
    max-width: 1240px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.35fr 0.9fr 1.05fr 0.95fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: start;
  }

  .footer-inner > * + * {
    border-left: 1px solid var(--footer-line);
    padding-left: clamp(2rem, 3.5vw, 3.5rem);
  }

  .footer-logo {
    display: inline-block;
    margin-bottom: 2rem;
  }

  .footer-logo img {
    display: block;
    width: min(310px, 100%);
    height: auto;
  }

  .footer-brand p {
    max-width: 300px;
    margin: 0;
    color: var(--footer-muted);
    font-size: 0.95rem;
    line-height: 1.8;
  }

  .google-link {
    display: inline-grid;
    place-items: center;
    width: 36px;
    height: 36px;
    margin-top: 26px;
    border-radius: 999px;
    background: var(--footer-teal);
    color: #fff;
    text-decoration: none;
    box-shadow: 0 6px 16px rgba(15, 125, 132, 0.2);
    transition: transform 180ms ease, background 180ms ease;
  }

  .google-link:hover {
    transform: translateY(-2px);
    background: #146f76;
  }

  .footer-col h3 {
    margin: 0 0 20px;
    font-family: "Playfair Display", Georgia, serif;
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--footer-teal);
    letter-spacing: 0.035em;
  }

  .footer-col h3::after {
    content: "";
    display: block;
    width: 38px;
    height: 2px;
    margin-top: 11px;
    background: var(--footer-teal);
  }

  .resources-title {
    margin-top: 16px !important;
  }

  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-col li {
    margin: 0;
  }

  .footer-col li + li {
    margin-top: 6px;
  }

  .footer-col a {
    color: #4f565e;
    text-decoration: none;
    transition: color 160ms ease;
  }

  .footer-col a:hover {
    color: var(--footer-teal);
  }

  .footer-links a {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 0.93rem;
  }

  .footer-links a::before {
    content: "›";
    color: var(--footer-teal);
    font-size: 1.2em;
    line-height: 1;
  }

  .footer-contact li {
    display: grid;
    grid-template-columns: 26px 1fr;
    gap: 14px;
    align-items: start;
    color: #4f565e;
    line-height: 1.55;
    font-size: 0.93rem;
  }

  .icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--footer-teal);
  }

  .icon svg {
    width: 20px;
    height: 20px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .hours-row {
    display: grid;
    grid-template-columns: 32px 1fr;
    gap: 16px;
    color: #4f565e;
  }

  .hours-row p {
    margin: 0;
    line-height: 1.65;
    font-size: 0.93rem;
  }

  .closed-note {
    position: relative;
    margin: 28px 0 0;
    padding-top: 22px;
    color: var(--footer-muted);
    font-style: italic;
    line-height: 1.8;
    font-size: 0.88rem;
  }

  .closed-note::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 48px;
    height: 1px;
    background: var(--footer-teal);
  }

  .footer-bottom {
    max-width: 1240px;
    margin: 52px auto 0;
    padding-top: 24px;
    border-top: 1px solid var(--footer-line);
    color: #687078;
    font-size: 0.88rem;
  }

  .footer-bottom p {
    margin: 0;
  }

  @media (max-width: 1050px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
    }

    .footer-inner > * {
      border-left: 0 !important;
      padding-left: 0 !important;
    }

    .footer-inner > *:nth-child(even) {
      border-left: 1px solid var(--footer-line) !important;
      padding-left: 2rem !important;
    }
  }

  @media (max-width: 700px) {
    .site-footer {
      margin-top: 4rem;
    }

    .footer-wave {
      top: -52px;
      height: 110px;
    }

    .footer-surface {
      padding: 3.75rem 1.25rem 1.75rem;
    }

    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      text-align: center;
    }

    .footer-inner > * {
      border-left: 0 !important;
      padding-left: 0 !important;
    }

    .footer-logo {
      display: block;
      text-align: center;
    }

    .footer-logo img {
      width: min(280px, 100%);
      margin: 0 auto;
    }

    .footer-brand p {
      margin: 0 auto;
    }

    .google-link {
      margin: 26px auto 0;
    }

    .footer-col h3::after {
      margin-left: auto;
      margin-right: auto;
    }

    .footer-links a {
      justify-content: center;
    }

    .footer-contact li {
      grid-template-columns: 1fr;
      gap: 4px;
      justify-items: center;
    }

    .icon {
      display: none;
    }

    .hours-row {
      grid-template-columns: 1fr;
      gap: 4px;
      justify-items: center;
    }

    .closed-note {
      text-align: center;
    }

    .closed-note::before {
      left: 50%;
      transform: translateX(-50%);
    }

    .footer-bottom {
      margin-top: 3rem;
      text-align: center;
    }
  }
</style>
