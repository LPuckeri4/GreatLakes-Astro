---
import { Picture, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import herobgSrc from '../../assets/images/herobg-1.jpg';

interface NavItem {
  label: string;
  href: string;
  image: ImageMetadata;
}

interface Props {
  title: string;
  navItems: NavItem[];
  currentPath: string;
  eyebrow?: string;
  heroSubtitle?: string;
}

const {
  title,
  navItems,
  currentPath,
  eyebrow = 'After Surgery Care',
  heroSubtitle = 'Clear recovery instructions to help you heal comfortably after oral surgery.',
} = Astro.props;
const hasCardHeader = Astro.slots.has('card-header');
const heroBg = await getImage({ src: herobgSrc, format: 'webp' });
---

{hasCardHeader ? (
  <div class="hero-section" style={`background-image: url('${heroBg.src}')`}>
    <div class="mx-auto max-w-7xl px-8 md:px-12 lg:px-16 py-14 md:py-16 text-center">
      <span class="hero-eyebrow">{eyebrow}</span>
      <h1 class="hero-title">{title}</h1>
      <p class="hero-subtitle">{heroSubtitle}</p>
      <div class="hero-actions">
        <button class="hero-btn" id="print-btn">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15">
            <polyline points="6 9 6 2 18 2 18 9"/>
            <path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/>
            <rect x="6" y="14" width="12" height="8"/>
          </svg>
          Print Instructions
        </button>
        <a href="tel:5199797227" class="hero-btn">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11.5a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .84h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
          </svg>
          Call Office 519-979-7227
        </a>
      </div>
    </div>
  </div>
) : (
  <div class="simple-hero">
    <h1 class="simple-title">{title}</h1>
    <div class="underline-teal-center"></div>
  </div>
)}

<!-- Page body -->
<div class="page-body pb-16">
  <div class="mx-auto max-w-7xl px-8 md:px-12 lg:px-16 pt-8 flex flex-col lg:flex-row gap-5">

    <!-- Sidebar -->
    <div class="sidebar-card w-full lg:w-[280px] shrink-0">
      <p class="sidebar-header">Select Procedure</p>
      <nav class="flex flex-col gap-2">
        {navItems.map(item => {
          const isActive = currentPath === item.href || currentPath.startsWith(item.href + '/');
          return (
            <a
              href={item.href}
              class:list={['nav-item', isActive && 'nav-item-active']}
            >
              <div class:list={['nav-icon-box', isActive && 'nav-icon-box-active']}>
                <Picture src={item.image} alt={item.label} widths={[40, 80, 120]} sizes="40px" formats={['webp', 'png']} class:list={['nav-img', isActive && 'nav-img-active']} />
              </div>
              <span class="nav-label">{item.label}</span>
            </a>
          );
        })}
      </nav>
    </div>

    <!-- Content -->
    <div class="flex-1 min-w-0">
      {hasCardHeader ? (
        <div>
          <div class="content-card">
            <div class="card-header-section">
              <slot name="card-header" />
            </div>
            <div class="card-body-section">
              <slot />
            </div>
          </div>
          <div class="assistance-box">
            <div class="assistance-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" width="22" height="22">
                <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 011 1V20a1 1 0 01-1 1C10.61 21 3 13.39 3 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.58a1 1 0 01-.25 1.01l-2.2 2.2z"/>
              </svg>
            </div>
            <div>
              <p class="assistance-title">Have Questions or Concerns?</p>
              <p class="assistance-text">Don't hesitate to call the office to speak with a nurse.</p>
              <a href="tel:5199797227" class="assistance-phone">519-979-7227</a>
            </div>
          </div>
        </div>
      ) : (
        <div class="pt-2">
          <slot />
        </div>
      )}
    </div>
  </div>
</div>

<style>
  /* ── Hero section ── */
  .hero-section {
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    border-bottom: 1px solid rgba(58,149,155,0.15);
  }
  .hero-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 60px 2rem 56px;
  }
  @media (min-width: 768px) {
    .hero-inner {
      padding: 64px 3rem 60px;
    }
  }
  @media (min-width: 1024px) {
    .hero-inner {
      padding: 72px 4rem 68px;
    }
  }
  .hero-eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #3A959B;
    margin-bottom: 14px;
  }
  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: 3rem;
    font-weight: 400;
    color: #1a2e35;
    margin: 0 0 16px 0;
    line-height: 1.15;
  }
  .hero-subtitle {
    font-size: 1rem;
    color: #5a6b72;
    margin: 0 0 30px 0;
    line-height: 1.6;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
  }
  .hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 18px;
    font-size: 0.825rem;
    font-weight: 500;
    color: #374151;
    background: rgba(255,255,255,0.85);
    border: 1px solid rgba(58,149,155,0.3);
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.15s ease;
    backdrop-filter: blur(4px);
    font-family: inherit;
  }
  .hero-btn:hover {
    background: white;
    border-color: #3A959B;
    color: #3A959B;
    box-shadow: 0 2px 8px rgba(58,149,155,0.15);
  }

  /* ── Simple header (surgery pages) ── */
  .simple-hero {
    padding: 48px 1rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .simple-title {
    font-size: 1.875rem;
    text-align: center;
    margin-bottom: 8px;
  }
  .underline-teal-center {
    height: 4px;
    width: 50px;
    background-color: #3A959B;
    margin: 0 auto;
  }

  /* ── Page body ── */
  .page-body {
    background-color: #f6f6f6;
    min-height: 60vh;
  }

  /* ── Sidebar card ── */
  .sidebar-card {
    background: white;
    border-radius: 18px;
    box-shadow: 0 2px 16px rgba(0,0,0,0.08);
    padding: 20px 16px 16px;
    align-self: flex-start;
  }
  .sidebar-header {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #999;
    margin: 0 4px 14px;
  }
  .nav-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 12px;
    border-radius: 12px;
    border: none;
    background: transparent;
    text-decoration: none;
    color: #374151;
    transition: background-color 0.15s ease;
  }
  .nav-item:hover {
    background-color: rgba(58, 149, 155, 0.06);
  }
  .nav-item-active {
    background-color: #3A959B !important;
    color: white !important;
  }
  .nav-icon-box {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .nav-img {
    width: 40px;
    height: 40px;
    object-fit: contain;
  }
  .nav-img-active {
    filter: brightness(0) invert(1);
  }
  .nav-label {
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.3;
  }

  /* ── Content card ── */
  .content-card {
    background: white;
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.09);
    overflow: hidden;
  }
  .card-header-section {
    background-color: rgba(58,149,155,0.1);
    border-bottom: 1px solid rgba(58,149,155,0.2);
    padding: 20px 20px;
  }
  @media (min-width: 640px) {
    .card-header-section { padding: 32px 44px; }
  }
  .card-header-section :global(h2) {
    font-family: 'Playfair Display', serif;
    font-size: 1.75rem;
    font-weight: 400;
    color: #222222;
    margin: 0 0 10px 0;
    line-height: 1.3;
  }
  .card-header-section :global(p) {
    font-size: 0.9rem;
    color: #555;
    line-height: 1.6;
    margin: 0;
  }
  .card-body-section {
    padding: 20px 20px 32px;
  }
  @media (min-width: 640px) {
    .card-body-section { padding: 28px 44px 44px; }
  }

  /* ── Assistance box ── */
  .assistance-box {
    margin-top: 20px;
    border-radius: 12px;
    border-left: 4px solid #3A959B;
    background: linear-gradient(to right, rgba(58,149,155,0.1), rgba(58,149,155,0.04));
    box-shadow: 0 2px 8px rgba(0,0,0,0.07);
    display: flex;
    align-items: flex-start;
    gap: 18px;
    padding: 20px 24px;
  }
  .assistance-icon {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background-color: #3A959B;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .assistance-title {
    font-weight: 600;
    color: #222222;
    margin-bottom: 6px;
    font-size: 0.95rem;
  }
  .assistance-text {
    font-size: 0.875rem;
    color: #555;
    line-height: 1.6;
    margin: 0 0 6px 0;
  }
  .assistance-phone {
    font-size: 0.95rem;
    font-weight: 600;
    color: #3A959B;
    text-decoration: none;
  }
  .assistance-phone:hover {
    text-decoration: underline;
  }
</style>

<script>
  // Open first accordion on load
  const firstAccordion = document.querySelector('.card-body-section details');
  if (firstAccordion) (firstAccordion as HTMLDetailsElement).open = true;

  // Print button — opens all accordions, prints, restores state
  const printBtn = document.getElementById('print-btn');
  if (printBtn) {
    printBtn.addEventListener('click', () => {
      const accordions = Array.from(
        document.querySelectorAll('.card-body-section details')
      ) as HTMLDetailsElement[];
      const wasOpen = accordions.map(d => d.open);
      accordions.forEach(d => (d.open = true));
      window.print();
      // Restore after print dialog closes
      setTimeout(() => {
        accordions.forEach((d, i) => (d.open = wasOpen[i]));
      }, 500);
    });
  }
</script>

<style is:global>
@media print {
  /* Hide everything except the content card */
  header,
  .hero-section,
  .sidebar-card,
  .assistance-box,
  .page-body > div > *:not(.flex-1) {
    display: none !important;
  }
  .page-body > div {
    display: block !important;
    padding: 0 !important;
    max-width: 100% !important;
  }
  .flex-1 {
    width: 100% !important;
  }
  .content-card {
    box-shadow: none !important;
    border-radius: 0 !important;
  }

  /* Card header */
  .card-header-section {
    background: none !important;
    border-bottom: 2px solid #3A959B !important;
    padding: 0 0 16px 0 !important;
  }
  .card-header-section h2 {
    font-size: 1.6rem !important;
    margin-bottom: 6px !important;
  }
  .card-header-section p {
    margin: 0 !important;
  }

  /* Card body */
  .card-body-section {
    padding: 0 !important;
  }

  /* Force all accordions open */
  details {
    display: block !important;
  }
  details > summary {
    padding: 12px 0 !important;
    border-bottom: 1px solid #e5e5e5 !important;
    font-weight: 600 !important;
  }
  details > .accordion-body {
    display: block !important;
    padding: 8px 0 16px !important;
  }
  /* Hide the chevron circles */
  .accordion-chevron-wrap {
    display: none !important;
  }

  /* General print cleanup */
  * {
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }
  body {
    font-size: 11pt !important;
  }
  .page-body {
    background: white !important;
    padding: 0 !important;
  }
}
</style>
